<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="PizzaGo">
    <meta name="theme-color" content="#ffffff">
    <link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='50' fill='%23FF5A3A'/%3E%3Ctext x='50' y='67' font-size='50' text-anchor='middle' fill='white' font-family='Arial'%3E🍕%3C/text%3E%3C/svg%3E">
    <title>PizzaGo — заказ пиццы</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: #f8f9fc; color: #1c1e24; padding-bottom: 80px; line-height: 1.4; }
        .screen { display: none; padding: 20px 16px 30px; animation: fadeIn 0.25s ease; }
        .screen.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(8px);} to { opacity: 1; transform: translateY(0);} }
        .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.96); backdrop-filter: blur(20px); border-top: 0.5px solid rgba(0,0,0,0.1); display: flex; justify-content: space-around; align-items: center; padding: 10px 20px 22px; z-index: 100; }
        .nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; background: none; border: none; font-size: 12px; font-weight: 500; color: #8e8e93; cursor: pointer; padding: 6px 16px; border-radius: 30px; font-family: inherit; }
        .nav-item.active { color: #ff5a3a; }
        .nav-icon { font-size: 24px; position: relative; }
        .cart-badge { position: absolute; top: -6px; right: -12px; background: #ff5a3a; color: white; font-size: 11px; font-weight: bold; min-width: 18px; height: 18px; border-radius: 30px; display: flex; align-items: center; justify-content: center; padding: 0 5px; }
        .pizza-list { display: flex; flex-direction: column; gap: 16px; margin-top: 8px; }
        .pizza-card { background: white; border-radius: 24px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center; gap: 12px; }
        .pizza-info { flex: 1; }
        .pizza-name { font-size: 18px; font-weight: 600; margin-bottom: 4px; }
        .pizza-desc { font-size: 13px; color: #6c6e78; margin-bottom: 6px; }
        .pizza-price { font-weight: 700; color: #ff5a3a; font-size: 17px; }
        .add-button { background: #ff5a3a; border: none; padding: 12px 18px; border-radius: 40px; font-weight: 600; font-size: 15px; color: white; cursor: pointer; transition: 0.2s; min-width: 90px; }
        .add-button:active { transform: scale(0.96); }
        .cart-item { background: white; border-radius: 20px; padding: 14px; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
        .cart-item-info { flex: 2; }
        .cart-item-name { font-weight: 600; font-size: 16px; }
        .cart-item-price { font-size: 14px; color: #ff5a3a; }
        .cart-item-controls { display: flex; align-items: center; gap: 12px; background: #f2f2f6; padding: 6px 12px; border-radius: 40px; }
        .cart-qty-btn { background: white; border: none; width: 32px; height: 32px; border-radius: 30px; font-size: 20px; font-weight: 600; cursor: pointer; }
        .cart-qty { font-weight: 600; min-width: 28px; text-align: center; }
        .delete-item { background: none; border: none; font-size: 22px; cursor: pointer; padding: 8px; color: #ff3b30; }
        .cart-total { background: white; border-radius: 28px; padding: 16px; margin: 20px 0 16px; display: flex; justify-content: space-between; font-weight: 700; font-size: 20px; }
        .btn-primary { background: #ff5a3a; border: none; width: 100%; padding: 16px; border-radius: 44px; color: white; font-weight: 600; font-size: 18px; cursor: pointer; margin-top: 8px; }
        .btn-secondary { background: #e9ecef; border: none; width: 100%; padding: 16px; border-radius: 44px; font-weight: 600; font-size: 17px; cursor: pointer; margin-top: 12px; color: #1c1e24; }
        .form-group { margin-bottom: 20px; }
        .form-group label { font-weight: 500; margin-bottom: 6px; display: block; }
        .form-group input, .form-group textarea { width: 100%; padding: 14px 16px; font-size: 16px; border: 1px solid #e2e4e8; border-radius: 28px; background: white; font-family: inherit; }
        .toast-message { position: fixed; bottom: 100px; left: 20px; right: 20px; background: #1c1e24e6; backdrop-filter: blur(8px); color: white; text-align: center; padding: 12px; border-radius: 40px; z-index: 200; transition: opacity 0.2s; opacity: 0; pointer-events: none; }
        .toast-message.show { opacity: 1; }
        h2 { font-size: 28px; font-weight: 700; margin-bottom: 20px; }
        .empty-cart { text-align: center; padding: 48px 20px; color: #8e8e93; }
        .success-screen { text-align: center; padding: 40px 20px; }
        .success-icon { font-size: 72px; margin-bottom: 24px; }
    </style>
</head>
<body>
<div id="menuScreen" class="screen active">
    <h2>🍕 Меню</h2>
    <div id="pizzaListContainer" class="pizza-list"></div>
</div>
<div id="cartScreen" class="screen">
    <h2>🛒 Корзина</h2>
    <div id="cartItemsContainer"></div>
    <div id="cartTotalContainer"></div>
    <button id="checkoutBtn" class="btn-primary">Оформить заказ</button>
</div>
<div id="checkoutScreen" class="screen">
    <h2>📝 Доставка</h2>
    <form id="orderForm">
        <div class="form-group"><label>Имя *</label><input type="text" id="nameInput" placeholder="Анна" required></div>
        <div class="form-group"><label>Телефон *</label><input type="tel" id="phoneInput" placeholder="+7 999 123-45-67" required></div>
        <div class="form-group"><label>Адрес *</label><input type="text" id="addressInput" placeholder="ул. Пиццерийная, 10" required></div>
        <div class="form-group"><label>Комментарий</label><textarea id="commentInput" rows="2"></textarea></div>
        <button type="submit" class="btn-primary" id="submitOrderBtn">Отправить заказ</button>
        <button type="button" id="backToCartFromCheckout" class="btn-secondary">Назад</button>
    </form>
</div>
<div id="successScreen" class="screen">
    <div class="success-screen"><div class="success-icon">✅🎉</div><h2>Заказ отправлен!</h2><p style="margin:16px 0">Скоро с вами свяжется оператор.</p><button id="resetAfterSuccessBtn" class="btn-primary">В меню</button></div>
</div>
<div class="bottom-nav">
    <button class="nav-item" data-screen="menu"><span class="nav-icon">🍕</span><span>Меню</span></button>
    <button class="nav-item" data-screen="cart"><span class="nav-icon">🛒<span id="cartCounterBadge" class="cart-badge" style="display: none;">0</span></span><span>Корзина</span></button>
</div>
<div id="toastMsg" class="toast-message"></div>

<script>
    // ========== ВАШ URL CLOUDFLARE WORKER ==========
    const TELEGRAM_PROXY_URL = "https://spring-wave-281c.pfnp12.workers.dev";
    
    const PIZZAS = [
        { id: 1, name: "Маргарита", description: "томат, сыр, базилик", price: 8 },
        { id: 2, name: "Пепперони", description: "острая пепперони, моцарелла", price: 10 },
        { id: 3, name: "Четыре сыра", description: "моцарелла, пармезан, горгонзола, фета", price: 11 },
        { id: 4, name: "BBQ курица", description: "курица, бекон, соус BBQ", price: 12 },
        { id: 5, name: "Вегетарианская", description: "перец, грибы, оливки, кукуруза", price: 9 }
    ];

    let cart = [];

    function loadCart() {
        const saved = localStorage.getItem("pizza_cart");
        if (saved) try { cart = JSON.parse(saved); } catch(e) { cart = []; }
        else cart = [];
        updateCartUI();
        updateCartBadge();
    }
    function saveCart() {
        localStorage.setItem("pizza_cart", JSON.stringify(cart));
        updateCartUI();
        updateCartBadge();
    }
    function showToast(msg, dur=2000) {
        const t = document.getElementById("toastMsg");
        if (!t) return;
        t.innerText = msg;
        t.classList.add("show");
        setTimeout(() => t.classList.remove("show"), dur);
    }
    function addToCart(pizza) {
        const existing = cart.find(i => i.id === pizza.id);
        if (existing) { existing.quantity += 1; showToast(`+1 ${pizza.name}`); }
        else { cart.push({ ...pizza, quantity: 1 }); showToast(`➕ ${pizza.name} добавлена`); }
        saveCart();
        animateAddButton(pizza.id);
    }
    function animateAddButton(id) {
        const btn = document.querySelector(`.add-button[data-id="${id}"]`);
        if (btn) { btn.style.transform = "scale(0.92)"; setTimeout(() => btn.style.transform = "", 150); }
    }
    function updateCartUI() {
        const container = document.getElementById("cartItemsContainer");
        const totalContainer = document.getElementById("cartTotalContainer");
        if (!container) return;
        if (cart.length === 0) {
            container.innerHTML = '<div class="empty-cart">🛍️ Корзина пуста</div>';
            if (totalContainer) totalContainer.innerHTML = "";
            return;
        }
        let html = "", sum = 0;
        cart.forEach(item => {
            sum += item.price * item.quantity;
            html += `<div class="cart-item">
                        <div class="cart-item-info">
                            <div class="cart-item-name">${escapeHtml(item.name)}</div>
                            <div class="cart-item-price">${item.price}€</div>
                        </div>
                        <div class="cart-item-controls">
                            <button class="cart-qty-btn" data-id="${item.id}" data-delta="-1">−</button>
                            <span class="cart-qty">${item.quantity}</span>
                            <button class="cart-qty-btn" data-id="${item.id}" data-delta="1">+</button>
                        </div>
                        <button class="delete-item" data-id="${item.id}">🗑️</button>
                    </div>`;
        });
        container.innerHTML = html;
        if (totalContainer) totalContainer.innerHTML = `<div class="cart-total"><span>Итого:</span><span>${sum}€</span></div>`;
        document.querySelectorAll('.cart-qty-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const id = parseInt(btn.dataset.id);
                const delta = parseInt(btn.dataset.delta);
                updateQuantity(id, delta);
            });
        });
        document.querySelectorAll('.delete-item').forEach(btn => {
            btn.addEventListener('click', () => removeCartItem(parseInt(btn.dataset.id)));
        });
    }
    function updateQuantity(id, delta) {
        const idx = cart.findIndex(i => i.id === id);
        if (idx !== -1) {
            const newQty = cart[idx].quantity + delta;
            if (newQty <= 0) cart.splice(idx, 1);
            else cart[idx].quantity = newQty;
            saveCart();
        }
    }
    function removeCartItem(id) {
        cart = cart.filter(i => i.id !== id);
        saveCart();
        showToast("Удалено");
    }
    function updateCartBadge() {
        const b = document.getElementById("cartCounterBadge");
        if (!b) return;
        const total = cart.reduce((s, i) => s + i.quantity, 0);
        if (total > 0) { b.style.display = "flex"; b.innerText = total > 99 ? "99+" : total; }
        else b.style.display = "none";
    }
    function renderMenu() {
        const container = document.getElementById("pizzaListContainer");
        if (!container) return;
        container.innerHTML = PIZZAS.map(p => `
            <div class="pizza-card">
                <div class="pizza-info">
                    <div class="pizza-name">${escapeHtml(p.name)}</div>
                    <div class="pizza-desc">${escapeHtml(p.description)}</div>
                    <div class="pizza-price">${p.price}€</div>
                </div>
                <button class="add-button" data-id="${p.id}">Добавить</button>
            </div>
        `).join('');
        document.querySelectorAll('.add-button').forEach(btn => {
            btn.addEventListener('click', () => {
                const id = parseInt(btn.dataset.id);
                const pizza = PIZZAS.find(p => p.id === id);
                if (pizza) addToCart(pizza);
            });
        });
    }
    function clearCartAfterOrder() { cart = []; saveCart(); }
    function validateOrder() {
        const name = document.getElementById("nameInput").value.trim();
        const phone = document.getElementById("phoneInput").value.trim();
        const addr = document.getElementById("addressInput").value.trim();
        if (!name) { showToast("Укажите имя"); return false; }
        if (!phone || phone.length < 5) { showToast("Введите корректный телефон"); return false; }
        if (!addr) { showToast("Укажите адрес"); return false; }
        if (cart.length === 0) { showToast("Корзина пуста"); return false; }
        return true;
    }
    async function sendOrderToTelegram(orderData) {
        if (!TELEGRAM_PROXY_URL) {
            console.warn("⚠️ Telegram proxy не настроен");
            showToast("⚠️ Ошибка: не настроен Telegram прокси");
            return false;
        }
        const itemsList = orderData.items.map(i => `🍕 ${i.name} — ${i.quantity} шт. × ${i.price}€ = ${i.quantity*i.price}€`).join("\n");
        const message = `🆕 **НОВЫЙ ЗАКАЗ**\n\n👤 **Клиент:** ${orderData.customerName}\n📞 **Телефон:** ${orderData.phone}\n🏠 **Адрес:** ${orderData.address}\n💬 **Комментарий:** ${orderData.comment || "—"}\n\n📦 **Состав заказа:**\n${itemsList}\n\n💰 **Итого:** ${orderData.totalPrice} €\n🕒 **Время:** ${new Date().toLocaleString()}`;
        try {
            const controller = new AbortController();
            setTimeout(() => controller.abort(), 5000);
            const resp = await fetch(TELEGRAM_PROXY_URL, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ text: message }),
                signal: controller.signal
            });
            const data = await resp.json();
            if (data.ok) { console.log("✅ Telegram отправлено"); return true; }
            else { console.error("❌ Ошибка прокси:", data); return false; }
        } catch (err) {
            console.error("❌ Ошибка отправки в Telegram:", err);
            return false;
        }
    }
    async function submitOrder(event) {
        event.preventDefault();
        if (!validateOrder()) return;
        const name = document.getElementById("nameInput").value.trim();
        const phone = document.getElementById("phoneInput").value.trim();
        const addr = document.getElementById("addressInput").value.trim();
        const comment = document.getElementById("commentInput").value.trim();
        const total = cart.reduce((s, i) => s + i.price * i.quantity, 0);
        const orderData = {
            customerName: name, phone: phone, address: addr, comment: comment,
            items: cart.map(i => ({ name: i.name, quantity: i.quantity, price: i.price })),
            totalPrice: total
        };
        const btn = document.getElementById("submitOrderBtn");
        const original = btn.innerText;
        btn.innerText = "Отправка...";
        btn.disabled = true;
        try {
            const ok = await sendOrderToTelegram(orderData);
            if (ok) {
                showToast(`Заказ на сумму ${total}€ отправлен!`);
                clearCartAfterOrder();
                document.getElementById("orderForm").reset();
                setActiveScreen("success");
            } else {
                showToast("Ошибка отправки. Попробуйте позже.");
            }
        } catch (e) {
            showToast("Ошибка сети");
        } finally {
            btn.innerText = original;
            btn.disabled = false;
        }
    }
    function setActiveScreen(screenId) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(`${screenId}Screen`).classList.add('active');
        document.querySelectorAll('.nav-item').forEach(nav => {
            if (nav.dataset.screen === screenId) nav.classList.add('active');
            else nav.classList.remove('active');
        });
        if (screenId === "cart") updateCartUI();
        if (screenId === "checkout" && cart.length === 0) {
            showToast("Корзина пуста");
            setActiveScreen("menu");
        }
    }
    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, m => m === '&' ? '&amp;' : m === '<' ? '&lt;' : '&gt;');
    }
    function setupPWA() {
        const sizes = [72, 96, 128, 144, 192, 384, 512];
        const icons = sizes.map(size => {
            const c = document.createElement('canvas');
            c.width = size; c.height = size;
            const ctx = c.getContext('2d');
            ctx.fillStyle = '#FF5A3A'; ctx.fillRect(0, 0, size, size);
            ctx.fillStyle = 'white'; ctx.font = `bold ${size*0.4}px system-ui`;
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            ctx.fillText('🍕', size/2, size/2);
            return { src: c.toDataURL('image/png'), sizes: `${size}x${size}`, type: 'image/png' };
        });
        const manifest = { name: "PizzaGo", short_name: "PizzaGo", start_url: ".", display: "standalone", theme_color: "#ffffff", background_color: "#f8f9fc", icons };
        const blob = new Blob([JSON.stringify(manifest)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        let link = document.querySelector('link[rel="manifest"]');
        if (!link) { link = document.createElement('link'); link.rel = 'manifest'; document.head.appendChild(link); }
        link.href = url;
        if ('serviceWorker' in navigator) {
            const swCode = `const CACHE='pizza-v7'; self.addEventListener('install',e=>e.waitUntil(caches.open(CACHE).then(c=>c.addAll([self.location.origin+'/',self.location.href])))); self.addEventListener('fetch',e=>e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request).then(res=>{const clone=res.clone();caches.open(CACHE).then(c=>c.put(e.request,clone));return res;}).catch(()=>caches.match('/')||new Response('Офлайн, но PizzaGo работает',{status:200,headers:{'Content-Type':'text/html'}}))))); self.addEventListener('activate',e=>e.waitUntil(caches.keys().then(keys=>Promise.all(keys.filter(k=>k!==CACHE).map(k=>caches.delete(k))))));`;
            const swBlob = new Blob([swCode], { type: 'application/javascript' });
            navigator.serviceWorker.register(URL.createObjectURL(swBlob)).catch(e => console.error(e));
        }
    }
    function init() {
        loadCart(); renderMenu(); setupPWA();
        document.querySelectorAll('.nav-item').forEach(btn => btn.addEventListener('click', () => setActiveScreen(btn.dataset.screen)));
        document.getElementById('checkoutBtn').addEventListener('click', () => { if (cart.length) setActiveScreen('checkout'); else showToast("Корзина пуста"); });
        document.getElementById('backToCartFromCheckout').addEventListener('click', () => setActiveScreen('cart'));
        document.getElementById('orderForm').addEventListener('submit', submitOrder);
        document.getElementById('resetAfterSuccessBtn').addEventListener('click', () => setActiveScreen('menu'));
    }
    init();
</script>
</body>
</html>
